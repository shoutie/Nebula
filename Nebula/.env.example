# Server
NODE_ENV=development
PORT=3009

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nebula
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

USE_MEMORY_STORAGE=false

# MXE Public Keys
VITE_BLACKJACK_MXE_PUBLIC_KEY=your_blackjack_mxe_public_key_hex
VITE_COINFLIP_MXE_PUBLIC_KEY=your_coinflip_mxe_public_key_hex

# Google Analytics (optional)
VITE_GA_ID=your_google_analytics_tracking_id
